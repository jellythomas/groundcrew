  "keywords": ["queue", "autonomous", "feedback", "human-in-the-loop", "task-management", "productivity"],
  "category": "productivity",
  "hooks": "hooks.json",
  "mcpServers": {
    "groundcrew": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/server/dist/index.js"],
